
# Added by skill
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ADMIN_USER_ID=

# Disable WhatsApp (only use Feishu)
DISABLE_WHATSAPP=true

# ===========================================
# Context Management (for 200K context models like GLM-5)
# ===========================================

# Trigger compact when remaining tokens < threshold
# Default: 50000 (50K) - good for 200K context
# Set to 0 to disable auto-compact
COMPACT_THRESHOLD_TOKENS=50000

# Memory flush: trigger silent turn to write memories BEFORE compact
# Should be higher than COMPACT_THRESHOLD_TOKENS so flush happens first
# Default: 60000 (60K) - gives 10K buffer for flush to complete
# Set to 0 to disable memory flush
MEMORY_FLUSH_THRESHOLD_TOKENS=60000

# Custom memory flush prompt (optional)
# Default uses OpenClaw-style dual memory structure:
# - MEMORY.md: permanent long-term memory
# - memory/YYYY-MM-DD.md: daily append-only log
#MEMORY_FLUSH_PROMPT=
